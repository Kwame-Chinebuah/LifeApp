{
  "expo": {
    "newArchEnabled": true,
    "name": "Life App",
    "slug": "LifeApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#12237F"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.kwamkit.lifeapp",
      "adaptiveIcon": {
        "foregroundImage": "./images/adaptive-icon.png",
        "backgroundColor": "#12237F"
      },
      "edgeToEdgeEnabled": true
    },
    "assetBundlePatterns": [
      "images/*",
      "assets/*"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8920454653234729~3861757950",
          "iosAppId": "ca-app-pub-8920454653234729~3861757950"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enablePngCrunchInReleaseBuilds": false
          }
        }
      ],
      "./withAdiRegistration"
    ],
    "extra": {
      "eas": {
        "projectId": "ef515f90-d352-40e7-9643-34c154cc9bd9"
      }
    }
  }
}
